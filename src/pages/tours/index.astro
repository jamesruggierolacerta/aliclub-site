---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";

const tours = await getCollection("tours");
const sorted = tours.slice().sort((a, b) => b.data.year - a.data.year);
---

<BaseLayout title="Tours">
  <div class="container">
    <div class="card">
      <h2 class="h2">Tours Archive</h2>
      <p class="meta">Select a year to view results and photos.</p>
      <hr class="rule" />

      <ul style="margin:0; padding-left: 18px;">
        {sorted.map((t) => (
          <li style="margin: 8px 0;">
            <a href={`/tours/${t.data.year}`} style="text-decoration:none;">
              <strong>{t.data.year}</strong> — {t.data.venue}
            </a>
            <span class="meta"> ({t.data.dates})</span>
          </li>
        ))}
      </ul>
    </div>
  </div>
</BaseLayout>
