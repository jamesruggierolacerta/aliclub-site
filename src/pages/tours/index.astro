---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";

const tours = await getCollection("tours");
const sorted = tours.slice().sort((a,b) => b.data.year - a.data.year);
---

<BaseLayout title="Tours">
  <div class="container">
    <div class="card">
      <h2 class="h2">Tours</h2>
      <p class="meta">Select a year.</p>
      <hr class="rule" />
      <ul>
        {sorted.map(t => (
          <li>
            {`/tours/${t.data.year}`}{t.data.year} — {t.data.venue}</a>
            <span class="meta"> ({t.data.dates})</span>
          </li>
        ))}
      </ul>
    </div>
  </div>
</BaseLayout>
