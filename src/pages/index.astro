---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";

const tours = await getCollection("tours");
const sorted = tours.slice().sort((a, b) => b.data.year - a.data.year);
const latest = sorted[0];
const recent = sorted.slice(0, 6);

const heroSrc =
  latest?.data.heroImage && latest.data.heroImage.trim().length > 0
    ? latest.data.heroImage
    : "/default-hero.jpg";

const intro =
  "Welcome to The Ali Club, est.1996 — a few blokes after a few laughs, a few beers, oh and the odd round of Golf";
---

<BaseLayout title="Home">

<section class="hero">
  <img
    src={heroSrc}
    alt="Ali Club tour"
    class="hero-img"
    loading="eager"
  />

  <div class="hero-inner">

      <div class="container">
        <h1>Ali Club</h1>
        <p>{intro}</p>
        {latest && (
          <p style="margin-top:10px; opacity:.95;">
            <strong>Next / Latest:</strong> {latest.data.year} {latest.data.venue} • {latest.data.dates}
          </p>
        )}
      </div>
    </div>
  </section>

  <div class="container">
    <div class="grid">
      <!-- Left: Latest tour card -->
      <div class="card">
        <h2 class="h2">Latest Tour</h2>

        {latest ? (
          <>
            <p class="meta">
              <strong>{latest.data.year}</strong> — {latest.data.venue}
            </p>
            <p class="meta">{latest.data.dates}</p>
            <p class="meta"><strong>Captain:</strong> {latest.data.captain}</p>

            {latest.data.highlights && latest.data.highlights.trim().length > 0 && (
              <>
                <hr class="rule" />
                <p style="margin:0;">{latest.data.highlights}</p>
              </>
            )}

            <hr class="rule" />

            <div style="display:flex; gap:10px; flex-wrap:wrap;">
              <a
                href={`/tours/${latest.data.year}`}
                style="display:inline-block; padding:10px 12px; border-radius:12px; background: var(--green); color:#fff; text-decoration:none;"
              >
                View {latest.data.year} Tour →
              </a>

              <a
                href="/tours"
                style="display:inline-block; padding:10px 12px; border-radius:12px; border:1px solid var(--border); background:#fff; text-decoration:none;"
              >
                Browse all tours
              </a>
            </div>
          </>
        ) : (
          <p class="meta">No tours added yet. Add your first one in /admin.</p>
        )}
      </div>

      <!-- Right: Quick links -->
      <div class="card">
        <h2 class="h2">Quick Links</h2>
        <p class="meta">Everything important in one click.</p>
        <hr class="rule" />

        <div style="display:grid; gap:10px;">
          <a href="/tours" style="text-decoration:none; padding:10px 12px; border-radius:12px; border:1px solid var(--border); background:#fff;">
            <strong>Tours</strong><br />
            <span class="meta">All years, results and photos</span>
          </a>

          <a href="/seniors" style="text-decoration:none; padding:10px 12px; border-radius:12px; border:1px solid var(--border); background:#fff;">
            <strong>Seniors Tour</strong><br />
            <span class="meta">Hawaii Cup & seniors history</span>
          </a>

          <a href="/hawaii-cup" style="text-decoration:none; padding:10px 12px; border-radius:12px; border:1px solid var(--border); background:#fff;">
            <strong>Hawaii Cup</strong><br />
            <span class="meta">Winners and notes</span>
          </a>

          <a href="/roll-call" style="text-decoration:none; padding:10px 12px; border-radius:12px; border:1px solid var(--border); background:#fff;">
            <strong>Roll Call</strong><br />
            <span class="meta">Who was there — by year</span>
          </a>

          <a href="/constitution" style="text-decoration:none; padding:10px 12px; border-radius:12px; border:1px solid var(--border); background:#fff;">
            <strong>Constitution</strong><br />
            <span class="meta">How the club runs</span>
          </a>
        </div>
      </div>
    </div>

    <!-- Recent tours list -->
    <div style="height:18px;"></div>

    <div class="card">
      <h2 class="h2">Recent Tours</h2>
      <p class="meta">Jump straight into a year.</p>
      <hr class="rule" />

      {recent.length ? (
        <ul style="margin:0; padding-left: 18px;">
          {recent.map((t) => (
            <li style="margin: 8px 0;">
              <a href={`/tours/${t.data.year}`} style="text-decoration:none;">
                <strong>{t.data.year}</strong> — {t.data.venue}
              </a>
              <span class="meta"> ({t.data.dates})</span>
            </li>
          ))}
        </ul>
      ) : (
        <p class="meta">No tours added yet.</p>
      )}
    </div>
  </div>
</BaseLayout>
