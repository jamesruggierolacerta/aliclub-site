---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";

const tours = await getCollection("tours");
const sorted = tours
  .slice()
  .sort((a, b) => b.data.year - a.data.year);

const latest = sorted[0];
---

<BaseLayout title="Home">
  {latest && (
    <section class="hero">
      {latest.data.heroImage ? (
        {latest.data.heroImage}
      ) : (
        /default-hero.jpg
      )}
      <div class="hero-inner">
        <div class="container">
          <h1>{latest.data.year} {latest.data.venue} Tour</h1>
          <p>{latest.data.dates} • Captain: {latest.data.captain}</p>
        </div>
      </div>
    </section>
  )}

  <div class="container">
    <div class="grid">
      <div class="card">
        <h2 class="h2">Latest Tour</h2>
        {latest ? (
          <>
            <p class="meta"><strong>{latest.data.year}</strong> — {latest.data.venue}</p>
            <p class="meta">{latest.data.dates}</p>
            <hr class="rule" />
            {`/tours/${latest.data.year}`}View {latest.data.year} Tour →</a>
          </>
        ) : (
          <p class="meta">No tours added yet.</p>
        )}
      </div>

      <div class="card">
        <h2 class="h2">Quick Links</h2>
        <p class="meta">/toursAll Tours</a></p>
        <p class="meta">/seniorsSeniors Tour</a></p>
        <p class="meta">/hawaii-cupHawaii Cup</a></p>
        <p class="meta">/roll-callRoll Call</a></p>
        <p class="meta">/constitutionConstitution</a></p>
      </div>
    </div>
  </div>
</BaseLayout>
