---
const { title } = Astro.props;
import "../styles/global.css";
import Logo from "../components/Logo.astro";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <title>{title ? `${title} | Ali Club` : "Ali Club"}</title>
    <meta name="description" content="Ali Club tours, results, photos and history." />
    /favicon.svg
  </head>
  <body>
    <header class="site-header">
      <div class="container">
        <div class="navbar">
          /
            <Logo />
            <span class="brand-title">Ali Club</span>
          </a>

          <nav class="nav" aria-label="Primary">
            /Home</a>
            /toursTours</a>
            /seniorsSeniors</a>
            /hawaii-cupHawaii Cup</a>
            /roll-callRoll Call</a>
            /constitutionConstitution</a>
          </nav>
        </div>
      </div>
    </header>

    <main class="main">
      <slot />
    </main>

    <footer class="site-footer">
      <div class="container">
        <div class="footer-row">
          <div class="small">© {new Date().getFullYear()} The Ali Club.</div>
          <div class="small">
            /toursPast Tours</a> &nbsp;|&nbsp;
            /seniorsSeniors</a> &nbsp;|&nbsp;
            /hawaii-cupHawaii Cup</a>
          </div>
        </div>
      </div>
    </footer>
  </body>
</html>
